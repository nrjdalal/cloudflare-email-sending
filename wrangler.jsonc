{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cloudflare-email-sending",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-21",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "vars": {
    "DOMAIN": "nrjdalal.com"
  },
  "send_email": [
    {
      "name": "EMAIL"
    }
  ]
}
